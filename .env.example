# LLM providers
OPENAI_API_KEY=sk-...
# Optional: swap any role to Anthropic via model_config.yaml
ANTHROPIC_API_KEY=sk-ant-...

# Database
DATABASE_URL=postgresql+asyncpg://edu:edu@localhost:5432/edu_agent

# Vector store
QDRANT_URL=http://localhost:6333

# LLM observability
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=http://localhost:3000

# Embedder (BGE-M3 via TEI)
TEI_EMBEDDER_URL=http://localhost:8080

# Services (inter-service, Phase 1 localhost)
CORPUS_SERVICE_URL=http://localhost:8001
AGENT_SERVICE_URL=http://localhost:8002
INGESTION_SERVICE_URL=http://localhost:8003

# Math verifier MCP server (SSE on port 8090)
MATH_VERIFIER_URL=http://localhost:8090

# Admin auth (Phase 1 HTTP Basic)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Environment
ENV=dev
